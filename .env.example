PORT=3000
HOST=0.0.0.0
CORS_ORIGINS="https://your-frontend.vercel.app"
MASTER_ADMIN_EMAIL="admin@evfleet.com.br"
MASTER_ADMIN_NAME="Master Admin"
MASTER_ADMIN_PASSWORD="change_me_master_password"
INFINITEPAY_HANDLE="your_infinitepay_handle"
INFINITEPAY_BASE_URL="https://api.infinitepay.io"
FRONTEND_PUBLIC_URL="https://your-frontend.vercel.app"
