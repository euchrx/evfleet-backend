// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id                      String    @id @default(uuid())
  name                    String
  document                String?
  slug                    String?   @unique
  active                  Boolean   @default(true)
  legalAcceptanceVersion  String?
  legalAcceptedAt         DateTime?
  legalAcceptedByUserId   String?
  legalAcceptedByUserName String?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  plans                Plan[]
  branches             Branch[]
  vehicles             Vehicle[]
  drivers              Driver[]
  users                User[]
  subscriptions        Subscription[]
  payments             Payment[]
  webhookEvents        WebhookEvent[]
  xmlImportBatches     XmlImportBatch[]
  xmlInvoices          XmlInvoice[]
  retailProductImports RetailProductImport[]
  supportRequests      SupportRequest[]
  vehicleDocuments     VehicleDocument[]
  TireMovement         TireMovement[]

  @@index([active])
}

model Branch {
  id        String   @id @default(uuid())
  name      String
  city      String
  state     String
  createdAt DateTime @default(now())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  vehicles             Vehicle[]
  xmlImportBatches     XmlImportBatch[]
  xmlInvoices          XmlInvoice[]
  retailProductImports RetailProductImport[]

  @@index([companyId])
}

model Vehicle {
  id                String                 @id @default(uuid())
  plate             String                 @unique
  model             String
  brand             String
  year              Int
  fipeValue         Decimal?               @db.Decimal(12, 2)
  vehicleType       VehicleType            @default(LIGHT)
  axleCount         Int?
  axleConfiguration AxleConfiguration?
  implementLinks    VehicleImplementLink[] @relation("VehicleToImplementLinks")
  implementOf       VehicleImplementLink[] @relation("ImplementToVehicleLinks")
  category          VehicleCategory        @default(CAR)
  chassis           String?                @unique
  renavam           String?                @unique
  acquisitionDate   DateTime?
  fuelType          FuelType?
  tankCapacity      Float?
  status            VehicleStatus          @default(ACTIVE)
  photoUrls         String[]               @default([])
  documentUrls      String[]               @default([])
  currentKm         Int                    @default(0)
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  costCenterId String?
  costCenter   CostCenter? @relation(fields: [costCenterId], references: [id])

  drivers                     Driver[]
  maintenanceRecords          MaintenanceRecord[]
  maintenancePlans            MaintenancePlan[]
  debts                       Debt[]
  fuelRecords                 FuelRecord[]
  trips                       Trip[]
  documents                   VehicleDocument[]
  retailProductImports        RetailProductImport[]
  tires                       Tire[]
  tireReadings                TireReading[]
  changeLogs                  VehicleChangeLog[]
  profilePhoto                VehicleProfilePhoto?
  TireMovement                TireMovement[]
  implementHistoryAsVehicle   VehicleImplementHistory[] @relation("VehicleImplementHistoryVehicle")
  implementHistoryAsImplement VehicleImplementHistory[] @relation("VehicleImplementHistoryImplement")

  @@index([companyId])
  @@index([branchId])
}

model VehicleProfilePhoto {
  id        String   @id @default(uuid())
  filename  String
  mimeType  String
  size      Int
  data      Bytes
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicleId String  @unique
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
}

enum VehicleType {
  LIGHT
  HEAVY
}

enum VehicleCategory {
  CAR
  TRUCK
  UTILITY
  IMPLEMENT
}

enum FuelType {
  GASOLINE
  ETHANOL
  DIESEL
  ARLA32
  FLEX
  ELECTRIC
  HYBRID
  CNG
}

enum VehicleStatus {
  ACTIVE
  MAINTENANCE
  SOLD
}

model CostCenter {
  id       String    @id @default(uuid())
  name     String
  vehicles Vehicle[]
}

enum Role {
  ADMIN
  FLEET_MANAGER
  REGIONAL_MANAGER
  BRANCH_MANAGER
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(BRANCH_MANAGER)
  createdAt DateTime @default(now())

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: Restrict)

  auditLogs                      AuditLog[]
  supportRequestsCreated         SupportRequest[]          @relation("SupportRequestCreatedBy")
  supportRequestsResponded       SupportRequest[]          @relation("SupportRequestRespondedBy")
  supportRequestsCompleted       SupportRequest[]          @relation("SupportRequestCompletedBy")
  vehicleImplementHistoryChanges VehicleImplementHistory[] @relation("VehicleImplementHistoryActor")

  @@index([companyId])
}

model Driver {
  id           String   @id @default(uuid())
  name         String
  cpf          String   @unique
  cnh          String   @unique
  cnhCategory  String
  cnhExpiresAt DateTime
  phone        String?
  status       String
  createdAt    DateTime @default(now())

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  fuelRecords FuelRecord[]
  trips       Trip[]
  documents   VehicleDocument[]
}

model MaintenanceRecord {
  id              String   @id @default(uuid())
  type            String
  description     String
  partsReplaced   String[] @default([])
  workshop        String?
  responsible     String?
  cost            Float
  km              Int
  maintenanceDate DateTime
  status          String
  notes           String?
  createdAt       DateTime @default(now())

  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  @@index([vehicleId])
}

model MaintenancePlan {
  id               String    @id @default(uuid())
  name             String
  planType         String
  intervalUnit     String
  intervalValue    Int
  alertBeforeKm    Int?      @default(500)
  alertBeforeDays  Int?      @default(7)
  nextDueDate      DateTime?
  nextDueKm        Int?
  lastExecutedDate DateTime?
  active           Boolean   @default(true)
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([nextDueDate])
}

model Debt {
  id             String       @id @default(uuid())
  description    String
  category       DebtCategory @default(FINE)
  amount         Float
  points         Int          @default(0)
  debtDate       DateTime
  dueDate        DateTime?
  referenceMonth String?
  creditor       String?
  isRecurring    Boolean      @default(false)
  status         String
  createdAt      DateTime     @default(now())

  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  @@index([vehicleId])
}

enum DebtCategory {
  FINE
  IPVA
  LICENSING
  INSURANCE
  TOLL
  TAX
  OTHER
}

model FuelRecord {
  id                           String    @id @default(uuid())
  invoiceNumber                String?
  liters                       Float
  totalValue                   Float
  km                           Int
  station                      String
  fuelType                     FuelType
  averageConsumptionKmPerLiter Float?
  isAnomaly                    Boolean   @default(false)
  anomalyReason                String?
  fuelDate                     DateTime
  createdAt                    DateTime  @default(now())
  sourceInvoiceKey             String?
  sourceInvoiceLineIndex       Int?
  sourceProductCode            String?
  sourcePlate                  String?
  sourceFuelDateTime           DateTime?
  sourceItems                  Json?

  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  driverId  String?
  driver    Driver?  @relation(fields: [driverId], references: [id], onDelete: SetNull)

  @@unique([sourceInvoiceKey, sourcePlate, fuelType])
  @@index([vehicleId])
  @@index([driverId])
  @@index([isAnomaly])
  @@index([invoiceNumber])
  @@index([sourceInvoiceKey, sourceInvoiceLineIndex])
  @@index([sourceInvoiceKey, sourcePlate, fuelType])
}

model VehicleChangeLog {
  id        String   @id @default(uuid())
  field     String
  oldValue  String?
  newValue  String?
  changedAt DateTime @default(now())

  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([changedAt])
}

enum VehicleImplementHistoryEventType {
  LINKED
  UNLINKED
  POSITION_CHANGED
}

model VehicleImplementHistory {
  id          String                           @id @default(uuid())
  eventType   VehicleImplementHistoryEventType
  position    Int?
  oldPosition Int?
  newPosition Int?
  changedAt   DateTime                         @default(now())

  vehicleId   String
  implementId String
  actorUserId String?

  vehicle   Vehicle @relation("VehicleImplementHistoryVehicle", fields: [vehicleId], references: [id], onDelete: Cascade)
  implement Vehicle @relation("VehicleImplementHistoryImplement", fields: [implementId], references: [id], onDelete: Cascade)
  actorUser User?   @relation("VehicleImplementHistoryActor", fields: [actorUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([vehicleId, changedAt])
  @@index([implementId, changedAt])
  @@index([actorUserId])
}

model AuditLog {
  id          String   @id
  action      String
  entity      String
  entityId    String?
  oldData     Json?
  newData     Json?
  metadata    Json?
  createdAt   DateTime @default(now())
  actorUserId String?
  actorUser   User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)
}

model SystemSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Trip {
  id          String    @id @default(uuid())
  origin      String
  destination String
  reason      String?
  departureKm Int       @map("kmStart")
  returnKm    Int?      @map("kmEnd")
  departureAt DateTime  @map("startedAt")
  returnAt    DateTime? @map("endedAt")
  status      String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  vehicleId String
  vehicle   Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  driverId  String?
  driver    Driver? @relation(fields: [driverId], references: [id], onDelete: SetNull)

  @@index([vehicleId])
  @@index([driverId])
  @@index([departureAt])
  @@map("TripUsage")
}

model VehicleDocument {
  id         String            @id @default(uuid())
  type       DocumentType
  ownerType  DocumentOwnerType @default(VEHICLE)
  name       String            @map("title")
  number     String?           @map("documentNumber")
  issueDate  DateTime?
  expiryDate DateTime?
  status     String
  issuer     String?           @map("provider")
  notes      String?
  fileUrl    String?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  driverId String?
  driver   Driver? @relation(fields: [driverId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([vehicleId])
  @@index([driverId])
  @@index([ownerType])
  @@index([expiryDate])
}

model VehicleImplementLink {
  id          String   @id @default(uuid())
  vehicleId   String
  implementId String
  position    Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vehicle   Vehicle @relation("VehicleToImplementLinks", fields: [vehicleId], references: [id], onDelete: Cascade)
  implement Vehicle @relation("ImplementToVehicleLinks", fields: [implementId], references: [id], onDelete: Cascade)

  @@unique([vehicleId, implementId])
  @@unique([vehicleId, position])
  @@index([vehicleId])
  @@index([implementId])
}

model Tire {
  id                  String         @id @default(uuid())
  serialNumber        String         @unique
  brand               String
  model               String
  size                String
  rim                 Int?
  purchaseDate        DateTime?
  purchaseCost        Float?
  status              TireStatus     @default(IN_STOCK)
  axlePosition        String?
  wheelPosition       String?
  movementsPrimary    TireMovement[] @relation("PrimaryTireMovement")
  movementsSecondary  TireMovement[] @relation("SecondaryTireMovement")
  currentKm           Int            @default(0)
  currentTreadDepthMm Float?
  currentPressurePsi  Float?
  targetPressurePsi   Float?
  minTreadDepthMm     Float          @default(3)
  installedAt         DateTime?
  notes               String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  readings TireReading[]

  @@index([vehicleId])
  @@index([status])
}

model TireReading {
  id           String   @id @default(uuid())
  readingDate  DateTime
  km           Int
  treadDepthMm Float
  pressurePsi  Float
  condition    String?
  notes        String?
  createdAt    DateTime @default(now())

  tireId    String
  tire      Tire     @relation(fields: [tireId], references: [id], onDelete: Cascade)
  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  @@index([tireId])
  @@index([vehicleId])
  @@index([readingDate])
}

model TireMovement {
  id               String           @id @default(cuid())
  companyId        String
  vehicleId        String?
  tireId           String?
  secondTireId     String?
  type             TireMovementType
  tireSerial       String
  secondTireSerial String?
  fromAxle         String?
  fromWheel        String?
  toAxle           String?
  toWheel          String?
  note             String?
  createdAt        DateTime         @default(now())

  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  vehicle    Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  tire       Tire?    @relation("PrimaryTireMovement", fields: [tireId], references: [id], onDelete: SetNull)
  secondTire Tire?    @relation("SecondaryTireMovement", fields: [secondTireId], references: [id], onDelete: SetNull)

  @@index([companyId, vehicleId, createdAt])
  @@index([companyId, tireId, createdAt])
}

enum TireMovementType {
  MOVE
  ROTATION
}

enum TireStatus {
  IN_STOCK
  INSTALLED
  MAINTENANCE
  RETREADED
  SCRAPPED
}

enum DocumentType {
  LICENSING
  INSURANCE
  IPVA
  LEASING_CONTRACT
  INSPECTION
  CNH
  EAR
  MOPP
  TOXICOLOGICAL_EXAM
  EMPLOYMENT_RECORD
  RG
  CPF_DOCUMENT
  DEFENSIVE_DRIVING
  TRUCAO_TRANSPORTE
  CRLV
  CIV
  CIPP
  ENVIRONMENTAL_AUTHORIZATION
  RNTRC
  OTHER
}

enum DocumentOwnerType {
  VEHICLE
  DRIVER
  GENERAL
}

enum PlanInterval {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  DRAFT
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
}

enum PaymentStatus {
  PENDING
  PAID
  EXPIRED
  FAILED
  REFUNDED
  CANCELED
}

enum BillingGateway {
  MANUAL
  INFINITEPAY
}

enum WebhookProcessStatus {
  PENDING
  PROCESSED
  FAILED
}

enum SupportRequestCategory {
  BUG
  IMPROVEMENT
  REQUEST
}

enum SupportRequestStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
}

enum XmlImportBatchStatus {
  PENDING
  PROCESSING
  COMPLETED
  COMPLETED_WITH_ERRORS
  FAILED
}

enum XmlInvoiceStatus {
  AUTHORIZED
  CANCELED
  DENIED
  UNKNOWN
}

enum XmlProcessingType {
  FUEL
  PRODUCT
  SERVICE
  RETAIL_PRODUCT
  UNKNOWN
}

enum XmlProcessingStatus {
  PENDING
  SUGGESTED
  PROCESSED
  IGNORED
  ERROR
}

enum AxleConfiguration {
  SINGLE
  DUAL
}

model Plan {
  id             String       @id @default(cuid())
  code           String       @unique
  name           String
  description    String?
  priceCents     Int
  currency       String       @default("BRL")
  interval       PlanInterval
  active         Boolean      @default(true)
  isPublic       Boolean      @default(true)
  isEnterprise   Boolean      @default(false)
  companyId      String?
  vehicleLimit   Int?
  userLimit      Int?
  trialDays      Int?
  features       Json?
  highlightLabel String?
  ctaLabel       String?
  sortOrder      Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  company       Company?       @relation(fields: [companyId], references: [id], onDelete: SetNull)
  subscriptions Subscription[]

  @@index([active])
  @@index([companyId])
  @@index([isPublic, active])
  @@index([isEnterprise, companyId, active])
}

model Subscription {
  id     String             @id @default(uuid())
  status SubscriptionStatus @default(DRAFT)

  startedAt          DateTime  @default(now())
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  nextBillingAt      DateTime?
  trialEndsAt        DateTime?
  canceledAt         DateTime?

  // Configuração comercial da assinatura
  trialDays          Int?
  graceDays          Int? @default(5)
  customPriceCents   Int?
  customVehicleLimit Int?

  // Snapshot comercial do plano no momento da contratação
  planNameSnapshot     String?
  planCodeSnapshot     String?
  priceCentsSnapshot   Int?
  vehicleLimitSnapshot Int?
  currencySnapshot     String?
  intervalSnapshot     PlanInterval?

  // Controle operacional
  graceEndsAt           DateTime?
  accessBlockedAt       DateTime?
  isCustomConfiguration Boolean   @default(false)

  externalCustomerId     String?
  externalSubscriptionId String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  planId String
  plan   Plan   @relation(fields: [planId], references: [id], onDelete: Restrict)

  payments      Payment[]
  webhookEvents WebhookEvent[]

  @@index([companyId])
  @@index([planId])
  @@index([status])
  @@index([graceEndsAt])
  @@index([accessBlockedAt])
}

model Payment {
  id                String         @id @default(uuid())
  gateway           BillingGateway @default(MANUAL)
  status            PaymentStatus  @default(PENDING)
  amountCents       Int
  currency          String         @default("BRL")
  dueDate           DateTime?
  paidAt            DateTime?
  gatewayReference  String?
  checkoutUrl       String?
  externalPaymentId String?
  invoiceUrl        String?
  metadata          Json?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([subscriptionId])
  @@index([status])
  @@index([dueDate])
  @@index([gatewayReference])
}

model WebhookEvent {
  id              String               @id @default(uuid())
  gateway         BillingGateway       @default(MANUAL)
  eventType       String
  externalEventId String?              @unique
  payload         Json
  processStatus   WebhookProcessStatus @default(PENDING)
  processedAt     DateTime?
  errorMessage    String?
  createdAt       DateTime             @default(now())

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  subscriptionId String?
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([subscriptionId])
  @@index([processStatus])
}

model XmlImportBatch {
  id             String               @id @default(uuid())
  fileName       String
  periodLabel    String?
  status         XmlImportBatchStatus @default(PENDING)
  totalFiles     Int                  @default(0)
  importedFiles  Int                  @default(0)
  duplicateFiles Int                  @default(0)
  errorFiles     Int                  @default(0)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  invoices XmlInvoice[]

  @@index([companyId])
  @@index([branchId])
  @@index([status])
  @@index([createdAt])
}

model XmlInvoice {
  id                          String              @id @default(uuid())
  fileName                    String
  folderName                  String?
  invoiceKey                  String              @unique
  number                      String?
  series                      String?
  issuedAt                    DateTime?
  issuerName                  String?
  issuerDocument              String?
  recipientName               String?
  recipientDocument           String?
  totalAmount                 Decimal?            @db.Decimal(14, 2)
  protocolNumber              String?
  invoiceStatus               XmlInvoiceStatus    @default(UNKNOWN)
  processingType              XmlProcessingType   @default(UNKNOWN)
  processingStatus            XmlProcessingStatus @default(PENDING)
  processedAt                 DateTime?
  linkedFuelRecordId          String?
  linkedMaintenanceRecordId   String?
  linkedCostId                String?
  linkedRetailProductImportId String?
  rawXml                      String
  createdAt                   DateTime            @default(now())
  updatedAt                   DateTime            @updatedAt

  batchId String
  batch   XmlImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  items                XmlInvoiceItem[]
  retailProductImports RetailProductImport[] @relation("RetailProductImportSource")

  @@index([batchId])
  @@index([companyId])
  @@index([branchId])
  @@index([issuedAt])
  @@index([linkedFuelRecordId])
  @@index([linkedMaintenanceRecordId])
  @@index([linkedCostId])
  @@index([linkedRetailProductImportId])
}

model XmlInvoiceItem {
  id          String   @id @default(uuid())
  productCode String?
  description String
  quantity    Decimal? @db.Decimal(14, 4)
  unitValue   Decimal? @db.Decimal(14, 4)
  totalValue  Decimal? @db.Decimal(14, 2)
  createdAt   DateTime @default(now())

  invoiceId String
  invoice   XmlInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model RetailProductImport {
  id               String    @id @default(uuid())
  supplierName     String?
  supplierDocument String?
  invoiceNumber    String?
  invoiceSeries    String?
  issuedAt         DateTime?
  totalAmount      Decimal?  @db.Decimal(14, 2)
  sourceInvoiceKey String?
  sourcePlate      String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Restrict)

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  vehicleId String?
  vehicle   Vehicle? @relation(fields: [vehicleId], references: [id], onDelete: SetNull)

  xmlInvoiceId String?
  xmlInvoice   XmlInvoice? @relation("RetailProductImportSource", fields: [xmlInvoiceId], references: [id], onDelete: Restrict)

  items RetailProductImportItem[]

  @@index([companyId])
  @@index([branchId])
  @@index([vehicleId])
  @@index([issuedAt])
  @@index([sourceInvoiceKey])
  @@index([sourcePlate])
}

model RetailProductImportItem {
  id                     String   @id @default(uuid())
  productCode            String?
  description            String
  category               String?
  quantity               Decimal? @db.Decimal(14, 4)
  unitValue              Decimal? @db.Decimal(14, 4)
  totalValue             Decimal? @db.Decimal(14, 2)
  sourceInvoiceKey       String?
  sourceInvoiceLineIndex Int?
  sourceProductCode      String?
  createdAt              DateTime @default(now())

  retailProductImportId String
  retailProductImport   RetailProductImport @relation(fields: [retailProductImportId], references: [id], onDelete: Cascade)

  @@unique([sourceInvoiceKey, sourceInvoiceLineIndex, sourceProductCode])
  @@index([retailProductImportId])
  @@index([sourceInvoiceKey, sourceInvoiceLineIndex])
}

model SupportRequest {
  id                    String                 @id @default(uuid())
  title                 String
  description           String
  category              SupportRequestCategory @default(REQUEST)
  status                SupportRequestStatus   @default(OPEN)
  responseMessage       String?
  estimatedCompletionAt DateTime?
  respondedAt           DateTime?
  completionMessage     String?
  completedAt           DateTime?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdByUserId String?
  createdByUser   User?   @relation("SupportRequestCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  respondedByUserId String?
  respondedByUser   User?   @relation("SupportRequestRespondedBy", fields: [respondedByUserId], references: [id], onDelete: SetNull)

  completedByUserId String?
  completedByUser   User?   @relation("SupportRequestCompletedBy", fields: [completedByUserId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([status])
  @@index([createdAt])
}
